rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Strict User-Ownership for personal data and Role-Based Access Control (RBAC).
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * General admin check.
     * Includes hardcoded UIDs for developers and a database-driven roles collection.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'zS64HBMM25aZwuqBoiiFg1kU9Tk2' ||
        request.auth.uid == 'c5yNNdozphYmPahMpu13nUnerVI2' ||
        request.auth.uid == 'RQxTHd3OakSJZ8HsjEPkO4jygg93' ||
        request.auth.uid == 'iyh9ADKMHYaiPZXma4iIdtiIXWE2' ||
        request.auth.uid == 'maZagyyZZuYrbLfdJtr50zsvSLm2' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    /** Ownership helper */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, write: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();

        match /items/{orderItemId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }

    match /wishlists/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    /** Support collectionGroup query for Admin Dashboard to see all orders */
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }

    /** OTP codes are internal */
    match /otp_codes/{otpCodeId} {
      allow read, write: if false;
    }

    /** Catalog Configuration */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /collections/{collectionId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /images/{imageId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /** App Configuration & Settings */
    match /configs/{configId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /** Storefront Content — public read, admin write */
    match /nav_items/{navItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /hero_slides/{slideId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /studio_reels/{reelId} {
      allow get: if true;
      allow list: if true; // The index must handle the where published == true and orderBy order asc 
      allow create, update, delete: if isAdmin();
    }
    
    /** Public User Reviews */
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow get, list: if true;
      // You must be logged in to create a review
      allow create: if isSignedIn();
      // Only admins can delete/update reviews (like hiding bad ones if needed)
      allow update, delete: if isAdmin();
    }

    /** RBAC Collection */
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, delete: if isAdmin();
      allow update: if false;
    }
  }
}
