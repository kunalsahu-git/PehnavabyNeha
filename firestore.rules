rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict User-Ownership model for personal data and a Role-Based Access Control (RBAC) 
     * model for administrative functions. 
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the signed-in user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the document exists and the signed-in user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /**
     * Checks if the signed-in user is a developer/bootstrap admin.
     * UIDs included here have master access during the initial setup phase.
     */
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.uid in [
        'zS64HBMM25aZwuqBoiiFg1kU9Tk2',
        'c5yNNdozphYmPahMpu13nUnerVI2',
        'RQxTHd3OakSJZ8HsjEPkO4jygg93'
      ];
    }

    /** General admin check combining hardcoded UIDs and database roles. */
    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can manage their own profile; Admins can see all.
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Sub-collections for user data
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /wishlistItems/{wishlistItemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();

        match /items/{orderItemId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }

    /** Support collectionGroup query for Admin Dashboard to see all orders */
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }

    /** OTP codes are internal and shouldn't be read by clients directly */
    match /otp_codes/{otpCodeId} {
      allow read, write: if false;
    }

    /** Catalog Configuration */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /collections/{collectionId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      // Public read access for the catalog
      allow get, list: if true;
      // Admin write access
      allow create, update, delete: if isAdmin();

      match /images/{imageId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /** App Configuration & Settings */
    match /configs/homepage/{configKey} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /configs/settings/{settingKey} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /** RBAC Collection */
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}