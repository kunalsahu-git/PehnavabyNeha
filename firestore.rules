rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Strict User-Ownership for personal data and Role-Based Access Control (RBAC).
     */

    // --- Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * General admin check.
     * Includes hardcoded UIDs for developers and a database-driven roles collection.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in [
          'zS64HBMM25aZwuqBoiiFg1kU9Tk2',
          'c5yNNdozphYmPahMpu13nUnerVI2',
          'RQxTHd3OakSJZ8HsjEPkO4jygg93'
        ] ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    /** Ownership helper */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Robust ownership rule: A user can always read/write their own document.
      allow get, write: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      // Sub-collections for user data
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /wishlistItems/{wishlistItemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();

        match /items/{orderItemId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }

    /** Support collectionGroup query for Admin Dashboard to see all orders */
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }

    /** OTP codes are internal */
    match /otp_codes/{otpCodeId} {
      allow read, write: if false;
    }

    /** Catalog Configuration */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /collections/{collectionId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /images/{imageId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /** App Configuration & Settings */
    match /configs/homepage/{configKey} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /configs/settings/{settingKey} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /** RBAC Collection */
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if false;
    }
  }
}
